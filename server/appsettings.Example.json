{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=GateKeeper;Username=postgres;Password=YOUR_POSTGRES_PASSWORD;",
    "Redis": "localhost:6379"
  },
  "JwtSettings": {
    "Secret": "YOUR_JWT_SECRET_KEY_MIN_32_CHARS_LONG",
    "ExpiryMinutes": "60",
    "Issuer": "GateKeeper",
    "Audience": "GateKeeperUsers"
  }
}
