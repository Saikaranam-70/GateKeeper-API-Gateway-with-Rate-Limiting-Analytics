@server_HostAddress = http://localhost:5041
@gatewayId = YOUR_GATEWAY_UUID_HERE

# Paste your JWT token from Login response here
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..mavRkxsgQrKTN_WJCDD9WlSxeRVOUz-G5khCP9sf0BY

### 1. Test Dummy End-to-End API (Queries DB time & Increments Redis hit counter)
GET {{server_HostAddress}}/api/dummy
Accept: application/json

### 2. Test Exception Handling Middleware (Triggers BadRequestException via Query Param)
GET {{server_HostAddress}}/api/dummy?triggerError=true
Accept: application/json

### 3. Register User
POST {{server_HostAddress}}/api/user/register
Content-Type: application/json
Accept: application/json

{
  "name": "Sai Karanam",
  "email": "saikaranam9@gmail.com",
  "password": "Sai@7065"
}

### 4. Login User
POST {{server_HostAddress}}/api/user/login
Content-Type: application/json
Accept: application/json

{
  "email": "saikaranam9@gmail.com",
  "password": "Sai@7065"
}

### 5. Get Current User Profile (JWT Protected)
GET {{server_HostAddress}}/api/auth/me
Accept: application/json
Authorization: Bearer {{token}}


### 6. Create Gateway (JWT required)
POST {{server_HostAddress}}/api/gateways
Content-Type: application/json
Authorization: Bearer {{token}}
{
  "name": "Payment Service Gateway",
  "description": "Proxies payment and refund services",
  "targetBaseUrl": "https://payments.internal:8080",
  "defaultRateLimitPerMin": 100,
  "routes": [
    { "path": "/payments/{**catch-all}", "methods": ["GET","POST"], "stripPrefix": false },
    { "path": "/refunds/{**catch-all}",  "methods": ["POST"],       "stripPrefix": true  }
  ]
}
### 7. Get All My Gateways
GET {{server_HostAddress}}/api/gateways
Authorization: Bearer {{token}}
### 8. Get Gateway by ID
GET {{server_HostAddress}}/api/gateways/{{gatewayId}}
Authorization: Bearer {{token}}
### 9. Update Gateway
PUT {{server_HostAddress}}/api/gateways/{{gatewayId}}
Content-Type: application/json
Authorization: Bearer {{token}}
{
  "name": "Updated Payment Gateway",
  "status": "inactive"
}
### 10. Delete Gateway
DELETE {{server_HostAddress}}/api/gateways/{{gatewayId}}
Authorization: Bearer {{token}}
