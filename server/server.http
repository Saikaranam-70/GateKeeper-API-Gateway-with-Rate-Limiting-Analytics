@server_HostAddress = http://localhost:5041
@gatewayId = YOUR_GATEWAY_UUID_HERE
@apiKeyId = YOUR_API_KEY_UUID_HERE

# Paste your JWT token from Login response here
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..9cYKrswg0O6ZJjMyFR8WxpvPThk8qU97Tge_WG_Ze-M

### 1. Test Dummy End-to-End API (Queries DB time & Increments Redis hit counter)
GET {{server_HostAddress}}/api/dummy
Accept: application/json

### 2. Test Exception Handling Middleware (Triggers BadRequestException via Query Param)
GET {{server_HostAddress}}/api/dummy?triggerError=true
Accept: application/json

### 3. Register User
POST {{server_HostAddress}}/api/user/register
Content-Type: application/json
Accept: application/json

{
  "name": "Sai Karanam",
  "email": "saikaranam9@gmail.com",
  "password": "Sai@7065"
}

### 4. Login User
POST {{server_HostAddress}}/api/user/login
Content-Type: application/json
Accept: application/json

{
  "email": "saikaranam9@gmail.com",
  "password": "Sai@7065"
}

### 5. Get Current User Profile (JWT Protected)
GET {{server_HostAddress}}/api/auth/me
Accept: application/json
Authorization: Bearer {{token}}


### 6. Create Gateway (JWT required)
POST {{server_HostAddress}}/api/gateways
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Payment Service Gateway",
  "description": "Proxies payment and refund services",
  "targetBaseUrl": "https://payments.internal:8080",
  "defaultRateLimitPerMin": 100,
  "routes": [
    { "path": "/payments/{**catch-all}", "methods": ["GET","POST"], "stripPrefix": false },
    { "path": "/refunds/{**catch-all}",  "methods": ["POST"],       "stripPrefix": true  }
  ]
}
### 7. Get All My Gateways
GET {{server_HostAddress}}/api/gateways
Authorization: Bearer {{token}}
### 8. Get Gateway by ID
GET {{server_HostAddress}}/api/gateways/{{gatewayId}}
Authorization: Bearer {{token}}
### 9. Update Gateway
PUT {{server_HostAddress}}/api/gateways/{{gatewayId}}
Content-Type: application/json
Authorization: Bearer {{token}}
{
  "name": "Updated Payment Gateway",
  "status": "inactive"
}
### 10. Delete Gateway
DELETE {{server_HostAddress}}/api/gateways/{{gatewayId}}
Authorization: Bearer {{token}}

### 11. Get Gateway Routes
GET {{server_HostAddress}}/api/gateways/{{gatewayId}}/routes
Accept: application/json
Authorization: Bearer {{token}}

### 12. Add Route to Gateway
POST {{server_HostAddress}}/api/gateways/{{gatewayId}}/routes
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "path": "/payments/{**catch-all}",
  "methods": ["GET","POST"],
  "stripPrefix": false
}

### 13. Update Route on Gateway
PUT {{server_HostAddress}}/api/gateways/{{gatewayId}}/routes/{{routeId}}
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "path": "/payments/{**catch-all}",
  "methods": ["GET","POST"],
  "stripPrefix": false,
  "isActive": true
}

### 14. Delete Route from Gateway
DELETE {{server_HostAddress}}/api/gateways/{{gatewayId}}/routes/{{routeId}}
Accept: application/json
Authorization: Bearer {{token}}

@routeId = YOUR_ROUTE_UUID_HERE

### ── API KEYS ────────────────────────────────────────────────────────────────

### 15. List All API Keys (JWT Protected)
GET {{server_HostAddress}}/api/api-keys
Accept: application/json
Authorization: Bearer {{token}}

### 16. Generate New API Key (JWT Protected)
### ⚠️  Copy rawApiKey from response — it is shown ONCE and never stored plain!
POST {{server_HostAddress}}/api/api-keys
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "gatewayId": "{{gatewayId}}",
  "label": "Production Key",
  "expiresAt": null
}

### 17. Revoke API Key (JWT Protected)
### Set @apiKeyId at the top of this file before calling
DELETE {{server_HostAddress}}/api/api-keys/{{apiKeyId}}
Authorization: Bearer {{token}}

### ── RATE LIMIT RULES ─────────────────────────────────────────────────────

### 18. List Rate Limit Rules (JWT Protected)
GET {{server_HostAddress}}/api/rate-limits?page=1&limit=20&gatewayId={{gatewayId}}
Authorization: Bearer {{token}}

### 19. Create Rate Limit Rule (JWT Protected)
POST {{server_HostAddress}}/api/rate-limits
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "gatewayId": "{{gatewayId}}",
  "scope": "global",
  "requestsPerWindow": 100,
  "windowSeconds": 60,
  "algorithm": "sliding-window",
  "burstAllowance": 20,
  "isActive": true
}

### 20. Update Rate Limit Rule (JWT Protected)
PUT {{server_HostAddress}}/api/rate-limits/{{rateLimitRuleId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "requestsPerWindow": 200,
  "windowSeconds": 30,
  "isActive": true
}

### 21. Delete Rate Limit Rule (JWT Protected)
DELETE {{server_HostAddress}}/api/rate-limits/{{rateLimitRuleId}}
Authorization: Bearer {{token}}

@rateLimitRuleId = YOUR_RATE_LIMIT_RULE_UUID_HERE

### ── ALERTS ───────────────────────────────────────────────────────────────

### 22. List Alerts (JWT Protected)
GET {{server_HostAddress}}/api/alerts?page=1&limit=20&gatewayId={{gatewayId}}
Authorization: Bearer {{token}}

### 23. Create Alert Rule (JWT Protected)
POST {{server_HostAddress}}/api/alerts
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "gatewayId": "{{gatewayId}}",
  "name": "High error rate",
  "metricType": "error-rate",
  "thresholdValue": 10,
  "thresholdUnit": "percent",
  "isActive": true
}

### 24. Update Alert Rule (JWT Protected)
PUT {{server_HostAddress}}/api/alerts/{{alertId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "thresholdValue": 15,
  "isActive": true
}

### 25. Delete Alert Rule (JWT Protected)
DELETE {{server_HostAddress}}/api/alerts/{{alertId}}
Authorization: Bearer {{token}}

@alertId = YOUR_ALERT_UUID_HERE

### ── GATEWAY ACTIONS ─────────────────────────────────────────────────────

### 26. Simulate Traffic for Gateway (JWT Protected)
POST {{server_HostAddress}}/api/gateways/{{gatewayId}}/simulate-traffic
Authorization: Bearer {{token}}

### 27. Update Gateway Status (JWT Protected)
POST {{server_HostAddress}}/api/gateways/{{gatewayId}}/status
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "active"
}

### ── ANALYTICS ───────────────────────────────────────────────────────────

### 28. Traffic Summary
GET {{server_HostAddress}}/api/analytics/{{gatewayId}}?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z&windowHours=24
Authorization: Bearer {{token}}

### 29. Latency Analytics
GET {{server_HostAddress}}/api/analytics/{{gatewayId}}/latency?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z&windowHours=24
Authorization: Bearer {{token}}

### 30. Error Analytics
GET {{server_HostAddress}}/api/analytics/{{gatewayId}}/errors?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z&windowHours=24
Authorization: Bearer {{token}}

### 31. Request Logs
GET {{server_HostAddress}}/api/analytics/{{gatewayId}}/requests?from=2026-01-01T00:00:00Z&to=2026-12-31T23:59:59Z&statusCode=500&page=1&limit=20
Authorization: Bearer {{token}}

### ── ADMIN / HEALTH ─────────────────────────────────────────────────────

### 32. Admin Platform Stats (Admin only)
GET {{server_HostAddress}}/api/admin/stats
Authorization: Bearer {{token}}

### 33. Health Check (Public)
GET {{server_HostAddress}}/api/health
Accept: application/json
